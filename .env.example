# ──────────────────────────────────────────────────────
# BANCO DE DADOS — SQLite (padrão de produção via Docker)
# ──────────────────────────────────────────────────────
# O Dockerfile já define DATABASE_URL="file:/data/prod.db"
# Só sobrescreva aqui se quiser uma pasta diferente.
DATABASE_URL="file:/data/prod.db"

# ──────────────────────────────────────────────────────
# NEXTAUTH — OBRIGATÓRIO no EasyPanel
# ──────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"

# URL pública da aplicação (usada pelo NextAuth para callbacks)
# Exemplo EasyPanel: https://pontocerto.seudominio.com
NEXTAUTH_URL="https://seu-app.easypanel.host"

# ──────────────────────────────────────────────────────
# E-MAIL (Resend) — opcional
# ──────────────────────────────────────────────────────
RESEND_API_KEY=""

# ──────────────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-app.easypanel.host"
