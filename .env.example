# ──────────────────────────────────────────────────────
# BANCO DE DADOS — PostgreSQL (obrigatório no EasyPanel)
# ──────────────────────────────────────────────────────
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=disable"

# ──────────────────────────────────────────────────────
# NEXTAUTH — OBRIGATÓRIO
# ──────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"

# URL pública da aplicação (usada pelo NextAuth para callbacks)
NEXTAUTH_URL="https://seu-app.easypanel.host"

# ──────────────────────────────────────────────────────
# E-MAIL (Resend) — opcional
# ──────────────────────────────────────────────────────
# Obtenha sua chave em: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"

# ──────────────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-app.easypanel.host"
